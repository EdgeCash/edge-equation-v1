# public/data/mlb/ holds the rolling daily snapshots (xlsx + csv + json).
# These ARE checked in — they're how Vercel serves "today's card" and
# how git history becomes the time-series record. Do NOT add public/
# to this ignore file.

# Generated by `python -m edge_equation.exporters.mlb.props_backtest`.
# This is a derived artifact (re-runnable from data/backfill/mlb/<season>/
# player_games.jsonl); not source.
data/backfill/mlb/props_backtest_summary.json

# Per-engine DuckDB caches generated at runtime by build_props_card,
# build_full_game_card, and the NRFI walk-forward trainer. These are
# re-buildable on demand from upstream data sources (Statcast,
# MLB Stats API, Odds API) and don't belong in git history --- they
# get rewritten on every workflow run and would balloon the repo.
data/props_cache/
data/fullgame_cache/
data/nrfi_cache/
