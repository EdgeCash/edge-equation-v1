# Edge Equation environment variables.
# Copy to .env and fill in real values for local dev, or set each as a
# secret in GitHub Actions / Vercel Project Settings for production.
#
# Every publisher silently degrades to the file failsafe when its credentials
# are missing, so you can stand up channels one at a time.

# ------------- Database -------------
# EDGE_EQUATION_DB can be a local SQLite path OR a hosted libSQL / Turso URL.
# - Local file (dev):  ./edge_equation.db  or  /var/lib/edge/edge.db
# - Turso (prod):      libsql://my-db-name.turso.io
#                      https://my-db-name.turso.io   (same endpoint)
# Dispatch is automatic: any libsql://, wss://, https://, http:// prefix
# routes to the HTTP pipeline adapter; everything else uses stdlib sqlite3.
EDGE_EQUATION_DB=./edge_equation.db

# Turso bearer token. Required ONLY when EDGE_EQUATION_DB points at a hosted
# database. Generate from the Turso dashboard or `turso db tokens create`.
TURSO_AUTH_TOKEN=

# Where to write failsafe .txt files when a publisher fails.
EDGE_EQUATION_FAILSAFE_DIR=./data/failsafes

# ------------- Ingestion -------------
# The Odds API free tier: 500 credits/month. Leave blank to skip the API and
# use the built-in mock sources.
THE_ODDS_API_KEY=

# ------------- X (Twitter) publisher -------------
# Requires an X Developer account with Basic tier or higher (free tier is
# read-only). Generate an access token + secret under a Project + App with
# Read and Write user-context permissions.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ------------- Discord publisher -------------
# Discord channel -> Integrations -> Webhooks -> New Webhook -> Copy URL.
DISCORD_WEBHOOK_URL=

# ------------- Email publisher + failsafe -------------
# Uses stdlib smtplib with STARTTLS. For Gmail, set SMTP_USER + SMTP_PASSWORD
# to your address + an App Password (NOT your account password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Where daily card emails go (publication list or operator address).
EMAIL_TO=
# Where failsafe alerts go when a publisher fails. Typically the operator's
# personal inbox.
SMTP_TO=

# ------------- Vercel cron auth -------------
# Bearer token required by /cron/daily and /cron/evening. Vercel injects
# this automatically when set on the project; match it on the server side.
CRON_SECRET=
